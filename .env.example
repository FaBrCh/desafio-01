# ── Parte 1 — API ────────────────────────────────────────────
HEADLESS=true
MAX_CONCURRENT=5
PORT=8000
HOST=0.0.0.0

# OAuth 2.0 — credenciais da API (altere em produção!)
API_USERNAME=admin
API_PASSWORD=changeme
SECRET_KEY=super-secret-key-change-in-production
TOKEN_EXPIRE_MINUTES=60

# ── Parte 2 — Workflow / Hyperautomation ─────────────────────
WORKFLOW_API_BASE_URL=http://localhost:8000
WORKFLOW_API_USERNAME=admin
WORKFLOW_API_PASSWORD=changeme
WORKFLOW_GOOGLE_CREDENTIALS_PATH=credentials.json
WORKFLOW_GOOGLE_DRIVE_FOLDER_ID=<id-da-pasta-no-google-drive>
WORKFLOW_GOOGLE_SHEETS_ID=<id-da-planilha-google-sheets>
